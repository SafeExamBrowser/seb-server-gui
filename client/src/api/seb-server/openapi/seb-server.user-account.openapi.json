{
    "openapi": "3.1.0",
    "info": { "title": "OpenAPI definition", "version": "v0" },
    "servers": [{ "url": "" }],
    "paths": {
        "/useraccount": {
            "get": {
                "tags": ["UserAccount"],
                "summary": "Get a page of the specific domain entity. Sorting and filtering is applied before paging",
                "description": "Sorting: the sort parameter to sort the list of entities before paging\nthe sort parameter is the name of the entity-model attribute to sort with a leading '-' sign for\ndescending sort order. Note that not all entity-model attribute are suited for sorting while the most\nare.\n</p>\nFilter: The filter attributes accepted by this API depend on the actual entity model (domain object)\nand are of the form [domain-attribute-name]=[filter-value]. E.g.: name=abc or type=EXAM. Usually\nfilter attributes of text type are treated as SQL wildcard with %[text]% to filter all text containing\na given text-snippet.",
                "operationId": "getUserAccounts",
                "parameters": [
                    {
                        "name": "page_number",
                        "in": "query",
                        "description": "The number of the page to get from the whole list. If the page does not exists, the API retruns with the first page.",
                        "required": false,
                        "schema": { "type": "integer", "format": "int32" }
                    },
                    {
                        "name": "page_size",
                        "in": "query",
                        "description": "The size of the page to get.",
                        "required": false,
                        "schema": { "type": "integer", "format": "int32" }
                    },
                    {
                        "name": "sort",
                        "in": "query",
                        "description": "the sort parameter to sort the list of entities before paging",
                        "required": false,
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "institutionId",
                        "in": "query",
                        "description": "The institution identifier of the request.\nDefault is the institution identifier of the institution of the current user",
                        "required": false,
                        "schema": { "type": "integer" }
                    },
                    {
                        "name": "surname",
                        "in": "query",
                        "required": false,
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "active",
                        "in": "query",
                        "required": false,
                        "schema": { "type": "string" }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PageUserInfo"
                                }
                            }
                        }
                    }
                }
            },
            "put": {
                "tags": ["UserAccount"],
                "summary": "Modifies an already existing entity object of the specific type.",
                "description": "This expects application/json format for the response data and verifies consistencies within the definition of the specific entity object type. Missing (NULL) parameter that are not mandatory will be ignored and the original value will not be affected",
                "operationId": "editUserAccount",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UserInfo"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UserInfo"
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": ["UserAccount"],
                "summary": "Create user account",
                "description": "Creates user account from application/x-www-form-urlencoded fields matching UserMod.",
                "operationId": "createUserAccount",
                "parameters": [
                    {
                        "name": "institutionId",
                        "in": "query",
                        "description": "The institution identifier of the request.\nDefault is the institution identifier of the institution of the current user",
                        "schema": { "type": "integer" }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": { "$ref": "#/components/schemas/UserMod" }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Created user account.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UserInfo"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/useraccount/password": {
            "put": {
                "tags": ["UserAccount"],
                "summary": "Change a user account password",
                "operationId": "changeUserAccountPassword",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/PasswordChange"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "User account after password change.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UserInfo"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/useraccount/{modelId}/inactive": {
            "post": {
                "tags": ["UserAccount"],
                "summary": "Dectivate a single entity by its modelId.",
                "operationId": "deactivateUserAccount",
                "parameters": [
                    {
                        "name": "modelId",
                        "in": "path",
                        "description": "The model identifier of the entity object to deactivate.",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "requestBody": {
                    "content": { "application/x-www-form-urlencoded": {} }
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EntityProcessingReport"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/useraccount/{modelId}/active": {
            "post": {
                "tags": ["UserAccount"],
                "summary": "Activate a single entity by its modelId.",
                "operationId": "activateUserAccount",
                "parameters": [
                    {
                        "name": "modelId",
                        "in": "path",
                        "description": "The model identifier of the entity object to activate.",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "requestBody": {
                    "content": { "application/x-www-form-urlencoded": {} }
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EntityProcessingReport"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/useraccount/logout": {
            "post": {
                "tags": ["UserAccount"],
                "summary": "Record current user logout",
                "description": "Attempts to revoke the current bearer token and records a logout activity.",
                "operationId": "logUserAccountLogout",
                "responses": {
                    "200": { "description": "Logout activity recorded." }
                }
            }
        },
        "/register": {
            "post": {
                "tags": ["UserAccount"],
                "summary": "Register a user account",
                "description": "Self-registers an EXAM_SUPPORTER account from application/x-www-form-urlencoded fields matching UserMod.",
                "operationId": "registerUserAccount",
                "requestBody": {
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": { "$ref": "#/components/schemas/UserMod" }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Registered user account.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UserInfo"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/useraccount/{modelId}": {
            "get": {
                "tags": ["UserAccount"],
                "summary": "Get a single entity by its modelId.",
                "operationId": "getUserAccountById",
                "parameters": [
                    {
                        "name": "modelId",
                        "in": "path",
                        "description": "The model identifier of the entity object to get.",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "requestBody": {
                    "content": { "application/x-www-form-urlencoded": {} }
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UserInfo"
                                }
                            }
                        }
                    }
                }
            },
            "delete": {
                "tags": ["UserAccount"],
                "summary": "Deletes a single entity (and all its dependencies) by its modelId.",
                "description": "To check or report what dependent object also would be deleted for a certain entity object, please use the dependency endpoint to get a report of all dependent entity objects.",
                "operationId": "deleteUserAccount",
                "parameters": [
                    {
                        "name": "modelId",
                        "in": "path",
                        "description": "The model identifier of the entity object to get.",
                        "required": true,
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "bulkActionAddIncludes",
                        "in": "query",
                        "description": "Indicates if the following 'includes' parameter shall be processed or not.\n The default is false ",
                        "required": false,
                        "schema": { "type": "boolean", "default": false }
                    },
                    {
                        "name": "bulkActionIncludes",
                        "in": "query",
                        "description": "A comma separated list of names of the EntityType enumeration that defines all entity types that shall be included in the result.",
                        "required": false,
                        "schema": {
                            "type": "array",
                            "items": { "type": "string" }
                        }
                    }
                ],
                "requestBody": {
                    "content": { "application/x-www-form-urlencoded": {} }
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EntityProcessingReport"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/useraccount/supervisors": {
            "get": {
                "tags": ["UserAccount"],
                "summary": "Get active supporter user names",
                "description": "Returns active EXAM_SUPPORTER user account names for the given institution.",
                "operationId": "getSupervisorNames",
                "parameters": [
                    {
                        "name": "institutionId",
                        "in": "query",
                        "description": "Institution identifier. Defaults to the current user's institution.",
                        "required": false,
                        "schema": { "type": "integer" }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Active supporter user names.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/EntityName"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/useraccount/me": {
            "get": {
                "tags": ["UserAccount"],
                "summary": "Get the current user account",
                "operationId": "getCurrentUserAccount",
                "responses": {
                    "200": {
                        "description": "Current user account.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UserInfo"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "APIMessage": {
                "type": "object",
                "description": "Structured SEB Server API error or validation message.",
                "properties": {
                    "messageCode": {
                        "type": "string",
                        "description": "Stable SEB Server message code.",
                        "example": 1200
                    },
                    "systemMessage": {
                        "type": "string",
                        "description": "Short backend-defined message for the error.",
                        "example": "Field validation error"
                    },
                    "details": {
                        "type": "string",
                        "description": "Optional technical details for diagnostics."
                    },
                    "attributes": {
                        "type": "array",
                        "description": "Optional message attributes, usually field names or validation context.",
                        "items": { "type": "string" }
                    }
                }
            },
            "PageUserInfo": {
                "type": "object",
                "properties": {
                    "number_of_pages": {
                        "type": "integer",
                        "format": "int32",
                        "description": "The number of available pages for the specified page size."
                    },
                    "page_number": {
                        "type": "integer",
                        "format": "int32",
                        "description": "The actual page number. Starting with 1.",
                        "maximum": 2147483647,
                        "minimum": 1
                    },
                    "page_size": {
                        "type": "integer",
                        "format": "int32",
                        "description": "The the actual size of a page",
                        "maximum": 2147483647,
                        "minimum": 1
                    },
                    "sort": {
                        "type": "string",
                        "description": "The page sort column name"
                    },
                    "content": {
                        "type": "array",
                        "description": "The actual content objects of the page. Might be empty.",
                        "items": { "$ref": "#/components/schemas/UserInfo" }
                    },
                    "complete": { "type": "boolean" }
                }
            },
            "UserInfo": {
                "type": "object",
                "description": "User account read and update model.",
                "properties": {
                    "uuid": {
                        "type": "string",
                        "description": "User UUID.",
                        "example": "f91f9c0a-15a1-4c65-89c2-2b60310f2c12"
                    },
                    "institutionId": {
                        "type": "integer",
                        "description": "Institution identifier the user belongs to.",
                        "example": 1
                    },
                    "creationDate": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Creation timestamp."
                    },
                    "name": {
                        "type": "string",
                        "description": "First name of the user.",
                        "example": "Ada",
                        "maxLength": 255,
                        "minLength": 0
                    },
                    "surname": {
                        "type": "string",
                        "description": "Surname of the user.",
                        "example": "Lovelace",
                        "maxLength": 255,
                        "minLength": 0
                    },
                    "username": {
                        "type": "string",
                        "description": "Login username.",
                        "example": "ada.lovelace",
                        "maxLength": 255,
                        "minLength": 3
                    },
                    "email": {
                        "type": "string",
                        "description": "User email address.",
                        "example": "ada@example.org"
                    },
                    "active": {
                        "type": "boolean",
                        "description": "Whether the user account is active.",
                        "example": true
                    },
                    "directLogin": {
                        "type": "boolean",
                        "description": "Whether direct login is enabled for this account.",
                        "example": true
                    },
                    "localAccount": {
                        "type": "boolean",
                        "description": "Whether this is a local SEB Server account.",
                        "example": true
                    },
                    "language": {
                        "type": "string",
                        "description": "User locale.",
                        "example": "en"
                    },
                    "timezone": {
                        "type": "string",
                        "description": "User time zone.",
                        "example": "Europe/Zurich"
                    },
                    "userRoles": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "enum": [
                                "SEB_SERVER_ADMIN",
                                "INSTITUTIONAL_ADMIN",
                                "EXAM_ADMIN",
                                "EXAM_SUPPORTER",
                                "TEACHER"
                            ]
                        },
                        "minItems": 1,
                        "uniqueItems": true
                    },
                    "entityPrivileges": {
                        "type": "array",
                        "description": "Entity-level privileges assigned to the user.",
                        "items": {
                            "$ref": "#/components/schemas/EntityPrivilege"
                        }
                    },
                    "featurePrivileges": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/FeaturePrivilege"
                        }
                    }
                },
                "required": [
                    "active",
                    "institutionId",
                    "language",
                    "name",
                    "surname",
                    "timezone",
                    "userRoles",
                    "username",
                    "uuid"
                ]
            },
            "UserMod": {
                "type": "object",
                "description": "User account creation and self-registration form model.",
                "properties": {
                    "uuid": {
                        "type": "string",
                        "description": "User UUID. Omit this for new user creation."
                    },
                    "institutionId": {
                        "type": "integer",
                        "description": "Institution identifier the user belongs to.",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "description": "First name of the user.",
                        "example": "Ada",
                        "maxLength": 255,
                        "minLength": 0
                    },
                    "surname": {
                        "type": "string",
                        "description": "Surname of the user.",
                        "example": "Lovelace",
                        "maxLength": 255,
                        "minLength": 0
                    },
                    "username": {
                        "type": "string",
                        "description": "Login username.",
                        "example": "ada.lovelace",
                        "maxLength": 255,
                        "minLength": 3
                    },
                    "newPassword": {
                        "type": "string",
                        "format": "password",
                        "description": "New account password.",
                        "maxLength": 255,
                        "minLength": 8
                    },
                    "confirmNewPassword": {
                        "type": "string",
                        "format": "password",
                        "description": "Repeated new account password."
                    },
                    "email": {
                        "type": "string",
                        "description": "User email address.",
                        "example": "ada@example.org"
                    },
                    "language": {
                        "type": "string",
                        "description": "User locale.",
                        "example": "en"
                    },
                    "timezone": {
                        "type": "string",
                        "description": "User time zone.",
                        "example": "Europe/Zurich"
                    },
                    "localAccount": {
                        "type": "boolean",
                        "description": "Whether this is a local SEB Server account.",
                        "example": true
                    },
                    "directLogin": {
                        "type": "boolean",
                        "description": "Whether direct login is enabled for this account.",
                        "example": true
                    },
                    "userRoles": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "enum": [
                                "SEB_SERVER_ADMIN",
                                "INSTITUTIONAL_ADMIN",
                                "EXAM_ADMIN",
                                "EXAM_SUPPORTER",
                                "TEACHER"
                            ]
                        },
                        "minItems": 1,
                        "uniqueItems": true
                    },
                    "retypedNewPassword": {
                        "type": "object",
                        "properties": { "empty": { "type": "boolean" } }
                    },
                    "creationDate": { "type": "string", "format": "date-time" }
                },
                "required": [
                    "confirmNewPassword",
                    "institutionId",
                    "language",
                    "name",
                    "newPassword",
                    "surname",
                    "timezone",
                    "userRoles",
                    "username"
                ]
            },
            "PasswordChange": {
                "type": "object",
                "description": "Request model for changing a user account password.",
                "properties": {
                    "uuid": {
                        "type": "string",
                        "description": "User UUID whose password is changed.",
                        "example": "f91f9c0a-15a1-4c65-89c2-2b60310f2c12"
                    },
                    "password": {
                        "type": "string",
                        "format": "password",
                        "description": "Current password.",
                        "minLength": 1
                    },
                    "newPassword": {
                        "type": "string",
                        "format": "password",
                        "description": "New password.",
                        "maxLength": 255,
                        "minLength": 8
                    },
                    "confirmNewPassword": {
                        "type": "string",
                        "format": "password",
                        "description": "Repeated new password.",
                        "minLength": 1
                    }
                },
                "required": ["uuid"]
            },
            "EntityProcessingReport": {
                "type": "object",
                "description": "Result report for delete, activate, and deactivate bulk actions.",
                "properties": {
                    "source": {
                        "type": "array",
                        "description": "Entities requested for processing.",
                        "items": { "$ref": "#/components/schemas/EntityKey" },
                        "uniqueItems": true
                    },
                    "results": {
                        "type": "array",
                        "description": "Entities processed or detected as dependencies.",
                        "items": { "$ref": "#/components/schemas/EntityKey" },
                        "uniqueItems": true
                    },
                    "errors": {
                        "type": "array",
                        "description": "Per-entity processing errors.",
                        "items": {
                            "$ref": "#/components/schemas/EntityProcessingErrorEntry"
                        },
                        "uniqueItems": true
                    },
                    "bulkActionType": {
                        "type": "string",
                        "description": "Bulk action that produced this report.",
                        "enum": ["HARD_DELETE", "DEACTIVATE", "ACTIVATE"],
                        "example": "HARD_DELETE"
                    }
                },
                "required": ["bulkActionType", "errors", "results", "source"]
            },
            "EntityName": {
                "type": "object",
                "description": "Display name key for a SEB Server domain entity.",
                "properties": {
                    "modelId": {
                        "type": "string",
                        "description": "Entity model identifier.",
                        "example": "f91f9c0a-15a1-4c65-89c2-2b60310f2c12"
                    },
                    "entityType": {
                        "type": "string",
                        "description": "SEB Server domain entity type.",
                        "enum": [
                            "CONFIGURATION_ATTRIBUTE",
                            "CONFIGURATION_VALUE",
                            "VIEW",
                            "ORIENTATION",
                            "CONFIGURATION",
                            "CONFIGURATION_NODE",
                            "EXAM_CONFIGURATION_MAP",
                            "EXAM",
                            "EXAM_SEB_RESTRICTION",
                            "EXAM_PROCTOR_DATA",
                            "CLIENT_CONNECTION",
                            "REMOTE_PROCTORING_ROOM",
                            "SCREEN_PROCTORING_GROUP",
                            "CLIENT_EVENT",
                            "CLIENT_INSTRUCTION",
                            "INDICATOR",
                            "THRESHOLD",
                            "INSTITUTION",
                            "SEB_CLIENT_CONFIGURATION",
                            "LMS_SETUP",
                            "USER",
                            "USER_ROLE",
                            "USER_ACTIVITY_LOG",
                            "ADDITIONAL_ATTRIBUTES",
                            "WEBSERVICE_SERVER_INFO",
                            "CERTIFICATE",
                            "EXAM_TEMPLATE",
                            "BATCH_ACTION",
                            "CLIENT_INDICATOR",
                            "CLIENT_NOTIFICATION",
                            "CLIENT_GROUP",
                            "SEB_SECURITY_KEY_REGISTRY",
                            "ENTITY_PRIVILEGE",
                            "FEATURE_PRIVILEGE",
                            "SCHEDULED_DELETE",
                            "SCHEDULED_DELETE_INFO",
                            "CONFIGURATION_ATTRIBUTE_DEPRECATION"
                        ],
                        "example": "USER"
                    },
                    "name": {
                        "type": "string",
                        "description": "Human-readable entity name.",
                        "example": "Ada Lovelace"
                    }
                },
                "required": ["entityType", "modelId", "name"]
            },
            "EntityPrivilege": {
                "type": "object",
                "description": "Entity-level privilege assigned to a user account.",
                "properties": {
                    "id": {
                        "type": "integer",
                        "description": "Privilege record identifier.",
                        "example": 42
                    },
                    "entityType": {
                        "type": "string",
                        "description": "Entity type this privilege applies to.",
                        "enum": [
                            "CONFIGURATION_ATTRIBUTE",
                            "CONFIGURATION_VALUE",
                            "VIEW",
                            "ORIENTATION",
                            "CONFIGURATION",
                            "CONFIGURATION_NODE",
                            "EXAM_CONFIGURATION_MAP",
                            "EXAM",
                            "EXAM_SEB_RESTRICTION",
                            "EXAM_PROCTOR_DATA",
                            "CLIENT_CONNECTION",
                            "REMOTE_PROCTORING_ROOM",
                            "SCREEN_PROCTORING_GROUP",
                            "CLIENT_EVENT",
                            "CLIENT_INSTRUCTION",
                            "INDICATOR",
                            "THRESHOLD",
                            "INSTITUTION",
                            "SEB_CLIENT_CONFIGURATION",
                            "LMS_SETUP",
                            "USER",
                            "USER_ROLE",
                            "USER_ACTIVITY_LOG",
                            "ADDITIONAL_ATTRIBUTES",
                            "WEBSERVICE_SERVER_INFO",
                            "CERTIFICATE",
                            "EXAM_TEMPLATE",
                            "BATCH_ACTION",
                            "CLIENT_INDICATOR",
                            "CLIENT_NOTIFICATION",
                            "CLIENT_GROUP",
                            "SEB_SECURITY_KEY_REGISTRY",
                            "ENTITY_PRIVILEGE",
                            "FEATURE_PRIVILEGE",
                            "SCHEDULED_DELETE",
                            "SCHEDULED_DELETE_INFO",
                            "CONFIGURATION_ATTRIBUTE_DEPRECATION"
                        ],
                        "example": "EXAM"
                    },
                    "entityId": {
                        "type": "integer",
                        "description": "Entity identifier this privilege applies to.",
                        "example": 120
                    },
                    "userUuid": {
                        "type": "string",
                        "description": "User UUID that owns this privilege.",
                        "example": "f91f9c0a-15a1-4c65-89c2-2b60310f2c12"
                    },
                    "privilegeType": {
                        "type": "string",
                        "description": "Assigned privilege type.",
                        "enum": ["NONE", "ASSIGNED", "READ", "MODIFY", "WRITE"],
                        "example": "READ"
                    }
                }
